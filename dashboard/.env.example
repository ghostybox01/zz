# ── Optional: real brand logos via Brandfetch CDN ─────────────────────────
# Sign up at https://brandfetch.com/developers (free tier: 100k req/month)
# and paste your Client ID here, then copy this file to `.env.local`.
# When set, the AddonsStrip pulls official vendor logos via the Brandfetch
# CDN. When unset, the inline hand-rolled SVGs are used.
VITE_BRANDFETCH_CLIENT_ID=
